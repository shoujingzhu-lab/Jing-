# ============================================
# Quant Trading System — 环境配置
# ============================================
# 复制此文件为 .env 并修改对应值

# --- 应用 ---
APP_NAME=QuantTradingSystem
APP_VERSION=0.1.0
APP_ENV=development          # development | staging | production
DEBUG=true
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# --- 服务地址 ---
HOST=0.0.0.0
PORT=8000

# --- 数据库 ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quant_trading
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false

# TimescaleDB (时序数据)
TIMESCALE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quant_trading_ts

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# --- JWT 认证 ---
JWT_SECRET_KEY=change-me-to-a-real-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- 安全 ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
BCRYPT_COST=12

# --- 交易所 API 加密 ---
API_KEY_ENCRYPTION_KEY=change-me-aes-256-key-32-characters!

# --- Celery 任务队列 ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- 通知 ---
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@quant-trading.com

# --- 风控默认参数 ---
DEFAULT_LEVERAGE=3
DEFAULT_MAX_POSITION_PCT=0.1   # 单仓位最大占账户比例
DEFAULT_DAILY_LOSS_LIMIT=0.05  # 单日亏损熔断阈值
DEFAULT_MAX_DRAWDOWN=0.30      # 最大回撤熔断阈值

# --- 数据保留 ---
TICK_DATA_RETENTION_DAYS=90
MINUTE_KLINE_RETENTION_DAYS=365
DAILY_KLINE_RETENTION_DAYS=0   # 0 = 永久保留
